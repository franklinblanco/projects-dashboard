# Copy to .env for local dev, or set these as your host's service variables.

# Port the Node server listens on (Railway/most hosts inject PORT automatically).
PORT=8080

# Where the live projects.json is stored. Mount a persistent volume here in
# production so projects you add/edit survive redeploys. Defaults to ./data.
# DATA_DIR=/app/data

# --- Auth (GitHub OAuth) ---
# If OAuth is not configured, auth is DISABLED (fine for local dev only).

# Secret used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=
# Optional: session lifetime in ms (default 7 days).
# SESSION_TTL_MS=604800000

# Register an OAuth app at https://github.com/settings/developers. Callback URL:
#   https://YOUR-DOMAIN/api/auth/github/callback
# (for local dev use http://localhost:8080/api/auth/github/callback)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Comma-separated GitHub logins allowed to sign in. Leave blank only if you
# intend the instance to be open to ANY GitHub user.
GITHUB_ALLOWED_USERS=

# Optional: force the OAuth callback base URL if the auto-detected host is wrong.
# OAUTH_BASE_URL=https://YOUR-DOMAIN

# --- GitHub ---
# Personal access token (fine-grained, read-only repo scope) of the account
# whose repos you list. Optional but recommended: raises the API rate limit and
# allows reading private repos.
GITHUB_TOKEN=

# Set to "production" behind HTTPS so the session cookie is marked Secure.
NODE_ENV=production
