# Copy to .env for local dev, or set these in Railway's service variables.

# Port the Node server listens on (Railway sets PORT automatically).
PORT=8080

# --- Auth (GitHub OAuth) ---
# If OAuth is not configured, auth is DISABLED (local dev only).

# Secret used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=
# Optional: session lifetime in ms (default 7 days).
# SESSION_TTL_MS=604800000

# Register an app at https://github.com/settings/developers with callback URL:
#   https://dashboard.franklinblanco.dev/api/auth/github/callback
# (for local dev use http://localhost:8080/api/auth/github/callback)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Comma-separated GitHub logins allowed to sign in (default: franklinblanco).
GITHUB_ALLOWED_USERS=franklinblanco
# Optional: force the OAuth callback base URL if the auto-detected host is wrong.
# OAUTH_BASE_URL=https://dashboard.franklinblanco.dev

# --- GitHub ---
# Personal access token (classic or fine-grained, read-only repo scope).
# Optional but recommended: raises the API rate limit and allows private repos.
GITHUB_TOKEN=

# Set to "production" on Railway so cookies are marked Secure.
NODE_ENV=production
